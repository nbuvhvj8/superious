{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Outlier",
  "version": "0.1.0",
  "identifier": "ai.outlier.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:4028",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:vite && npm run desktop:prepare-sidecar"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Outlier",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https: data:; connect-src 'self' https: http://localhost:* ws://localhost:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "deb", "appimage", "rpm", "msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/outlier-sidecar"],
    "resources": {
      "../.next/standalone": "next-standalone",
      "../.next/static": "next-standalone/.next/static",
      "../public": "next-standalone/public",
      "sidecar/start-sidecar.js": "sidecar/start-sidecar.js"
    },
    "category": "Productivity",
    "shortDescription": "Autonomous research workstation for video script production",
    "longDescription": "Outlier is an autonomous research and content generation desktop application that captures verified web sources, generates structured video scripts, and manages recurring research jobs.",
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/nbuvhvj8/superious/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI4NzBGNTdCMDZERUJEMzcKUldRM3ZkNEdlL1Z3dUxzaTBXY2pZb0VDSmxxSTBSUHdVUkJJUGgwYkdFR013dlNyT2NxVmJyYmkK"
    }
  }
}
